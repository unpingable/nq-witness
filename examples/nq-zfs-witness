#!/usr/bin/env bash
# nq-zfs-witness — MVP reference implementation of a ZFS witness
# conforming to nq.witness.v0 / nq.witness.zfs.v0.
#
# Status: experimental / scar-tissue pass. Not production code.
# Deployment: install root-owned at a fixed path (e.g.
# /usr/local/libexec/nq-zfs-witness), grant sudo NOPASSWD for that
# exact path, OR — if /dev/zfs permissions allow non-root read —
# run it directly as the NQ user.
#
# Invocation: no arguments, ever. Reads pool state, emits the
# canonical JSON report to stdout, exits 0 on ok/partial and 1 only
# on helper-level failure where no meaningful report can be emitted.
#
# Scars captured on first contact (2026-04-17, lil-nas-x):
# - The SPEC's collection_mode enum ({embedded, exporter, textfile,
#   sudo_helper}) has no value for "unprivileged one-shot subprocess"
#   — which is exactly the legitimate shape this helper uses when
#   /dev/zfs is world-readable. We emit "sudo_helper" here as the
#   closest existing fit; the real shape is sudo-less subprocess
#   invocation. Fix in a follow-up SPEC pass after clarify/harden.
# - lil-nas-x pool "tank" has no configured spares despite earlier
#   gap notes claiming "two spares assigned." The physical spares
#   exist on the shelf but aren't in the pool config. No zfs_spare
#   observations from this helper on that deployment; zpool_spare
#   tag will be honest about that.

set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

readonly SCHEMA="nq.witness.v0"
readonly PROFILE_VERSION="nq.witness.zfs.v0"
readonly WITNESS_TYPE="zfs"
readonly MAX_POOLS=16
readonly MAX_VDEVS_PER_POOL=256

# ---------------------------------------------------------------------------
# Identity + timing
# ---------------------------------------------------------------------------

start_ns=$(date +%s%N)
collected_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
host=$(hostname)
id="zfs.local.${host}"

# ---------------------------------------------------------------------------
# State carried across the run
# ---------------------------------------------------------------------------

errors_json='[]'
observations_json='[]'
status="ok"

# Coverage is declared empty and tags are added as each collection step
# succeeds. Anything never added falls out as missing — the profile's
# conformance check should reject that, which is exactly the point:
# silent omission is the failure mode we want visible.
can_testify='[]'
# Tags the helper structurally does not emit (future profile extensions
# live here). Never sourced from this MVP implementation.
cannot_testify='["smart_drive_health","enclosure_slot_mapping","dataset_capacity","dataset_properties"]'

append_error() {
  local kind="$1" detail="$2"
  errors_json=$(jq -c --arg k "$kind" --arg d "$detail" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '. + [{kind:$k, detail:$d, observed_at:$ts}]' <<< "$errors_json")
}

append_observation() {
  # One argument: already-serialized JSON object.
  local obs="$1"
  observations_json=$(jq -c --argjson o "$obs" '. + [$o]' <<< "$observations_json")
}

add_coverage_tag() {
  local tag="$1"
  can_testify=$(jq -c --arg t "$tag" 'if index($t) then . else . + [$t] end' <<< "$can_testify")
}

demote_to_cannot_testify() {
  local tag="$1"
  can_testify=$(jq -c --arg t "$tag" 'map(select(. != $t))' <<< "$can_testify")
  cannot_testify=$(jq -c --arg t "$tag" 'if index($t) then . else . + [$t] end' <<< "$cannot_testify")
}

# ---------------------------------------------------------------------------
# Pool list (zfs_pool observations)
# ---------------------------------------------------------------------------

pool_list_raw=""
if ! pool_list_raw=$(timeout 5 zpool list -Hp -o name,size,alloc,free,frag,cap,health,readonly 2>&1); then
  append_error "zpool_list_failed" "zpool list returned non-zero"
  status="failed"
else
  add_coverage_tag "pool_state"
  add_coverage_tag "pool_capacity"
  add_coverage_tag "fragmentation"

  pool_names=()
  while IFS=$'\t' read -r name size alloc free frag cap health readonly_flag; do
    [[ -z "$name" ]] && continue
    pool_names+=("$name")

    # Health string maps to a small integer for sparse-exporter compat.
    # 0 ONLINE / 3 DEGRADED / 6 FAULTED / 9 SUSPENDED / other -> -1.
    case "$health" in
      ONLINE) health_numeric=0;;
      DEGRADED) health_numeric=3;;
      FAULTED) health_numeric=6;;
      SUSPENDED) health_numeric=9;;
      OFFLINE) health_numeric=4;;
      UNAVAIL) health_numeric=5;;
      REMOVED) health_numeric=8;;
      *) health_numeric=-1;;
    esac

    # zpool list -p emits frag as an integer percentage, or "-" when
    # undefined. Convert to 0.0-1.0 or null.
    if [[ "$frag" == "-" || -z "$frag" ]]; then
      frag_ratio="null"
    else
      frag_ratio=$(awk -v f="$frag" 'BEGIN{printf "%.4f", f/100}')
    fi

    readonly_bool="false"
    [[ "$readonly_flag" == "on" ]] && readonly_bool="true"

    obs=$(jq -n -c \
      --arg subject "$name" \
      --arg state "$health" \
      --argjson health_numeric "$health_numeric" \
      --argjson size "$size" \
      --argjson alloc "$alloc" \
      --argjson free "$free" \
      --argjson readonly "$readonly_bool" \
      --argjson frag "$frag_ratio" \
      '{kind:"zfs_pool", subject:$subject, state:$state, health_numeric:$health_numeric, size_bytes:$size, alloc_bytes:$alloc, free_bytes:$free, readonly:$readonly, fragmentation_ratio:$frag}'
    )
    append_observation "$obs"
  done <<< "$pool_list_raw"

  # Bound output per MAX_POOLS for safety (SPEC §Failure behavior rule 3).
  if (( ${#pool_names[@]} > MAX_POOLS )); then
    append_error "pool_count_exceeded_cap" "found ${#pool_names[@]} pools, cap is $MAX_POOLS; truncating"
    status="partial"
    pool_names=("${pool_names[@]:0:$MAX_POOLS}")
  fi
fi

# ---------------------------------------------------------------------------
# zpool status (per-vdev state, scan, spares)
# ---------------------------------------------------------------------------

status_raw=""
if ! status_raw=$(timeout 5 zpool status -P 2>&1); then
  append_error "zpool_status_failed" "zpool status returned non-zero or timed out"
  # Coverage for vdev / scan / spare tags is not added — which is the correct
  # shape: absence of tag = absence of coverage.
  status="partial"
else
  add_coverage_tag "vdev_state"
  add_coverage_tag "vdev_error_counters"
  add_coverage_tag "scrub_state"
  add_coverage_tag "scrub_completion"
  add_coverage_tag "spare_state"

  # Parse with awk. State machine:
  # - track current_pool from "pool:" lines
  # - on "scan:" capture the scan line (one per pool)
  # - between "config:" and the next blank-followed-by-errors, collect vdevs
  # - a "spares" line inside config switches us to spares mode
  vdev_count=0
  parsed=$(awk -v mvp_max="$MAX_VDEVS_PER_POOL" '
    BEGIN {
      current_pool = ""
      in_config = 0
      in_spares = 0
      scan_idx = 0
      vdev_idx = 0
      spare_idx = 0
      pool_errors_idx = 0
    }
    /^[[:space:]]*pool:[[:space:]]/ {
      split($0, a, "pool:")
      current_pool = a[2]
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", current_pool)
      in_config = 0
      in_spares = 0
      next
    }
    /^[[:space:]]*scan:[[:space:]]/ {
      split($0, a, "scan:")
      scan_line = a[2]
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", scan_line)
      printf("SCAN\t%s\t%s\n", current_pool, scan_line)
      next
    }
    /^config:/ {
      in_config = 1
      in_spares = 0
      next
    }
    /^errors:/ {
      in_config = 0
      in_spares = 0
      split($0, a, "errors:")
      err_line = a[2]
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", err_line)
      printf("POOL_ERRORS\t%s\t%s\n", current_pool, err_line)
      next
    }
    in_config == 1 {
      # Skip blank lines and the NAME STATE READ WRITE CKSUM header.
      if ($0 ~ /^[[:space:]]*$/) { in_spares = 0; next }
      if ($0 ~ /^[[:space:]]+NAME[[:space:]]+STATE/) { next }
      # The "spares" pseudo-header line.
      if ($1 == "spares") { in_spares = 1; next }

      # Leaf detection: a leaf has at least 5 fields and its second
      # field is a state string (ONLINE/DEGRADED/FAULTED/etc).
      # Non-leaf lines (pool itself, raidz groups) have the same
      # shape but their name matches the pool or a vdev_type prefix.
      name = $1
      state = $2
      read_err = $3
      write_err = $4
      cksum_err = $5
      note = ""
      if (NF > 5) {
        note = $6
        for (i = 7; i <= NF; i++) note = note " " $i
      }

      # Skip pool-level and group-level rows. Leaves are what the profile
      # calls for — device-level observations. We skip anything whose
      # name matches a known non-leaf pattern.
      if (name == current_pool) next
      if (name ~ /^raidz[0-9]*-/ || name ~ /^mirror-/ || name ~ /^spare-/ || name ~ /^log-/ || name ~ /^cache-/ || name ~ /^special-/ || name ~ /^dedup-/) {
        next
      }

      if (in_spares == 1) {
        # Spare-section entries: "ata-FOO-BAR  AVAIL" or
        # "ata-FOO-BAR  INUSE  currently in use"
        # State is in $2; no error counters; note in $3+.
        spare_state = $2
        spare_note = ""
        if (NF > 2) {
          spare_note = $3
          for (i = 4; i <= NF; i++) spare_note = spare_note " " $i
        }
        if (spare_idx < mvp_max) {
          printf("SPARE\t%s\t%s\t%s\t%s\n", current_pool, name, spare_state, spare_note)
          spare_idx++
        }
      } else {
        if (vdev_idx < mvp_max) {
          printf("VDEV\t%s\t%s\t%s\t%d\t%d\t%d\t%s\n", current_pool, name, state, read_err, write_err, cksum_err, note)
          vdev_idx++
        }
      }
    }
  ' <<< "$status_raw")

  # Process parsed lines into observations.
  while IFS=$'\t' read -r tag rest; do
    [[ -z "$tag" ]] && continue
    case "$tag" in
      SCAN)
        IFS=$'\t' read -r pool scan_line <<< "$rest"

        # "scrub repaired 0B in 04:12:17 with 0 errors on Sun Apr 12 07:26:33 2026"
        # "scrub canceled on Thu Dec 25 20:14:37 2025"
        # "resilver in progress since Mon Mar  1 ..."
        # "none requested"
        scan_type="none"
        scan_state="none"
        last_completed="null"
        errors_found=0

        if [[ "$scan_line" == scrub* ]]; then
          scan_type="scrub"
        elif [[ "$scan_line" == resilver* ]]; then
          scan_type="resilver"
        fi
        if [[ "$scan_line" == *"in progress"* ]]; then
          scan_state="in_progress"
        elif [[ "$scan_line" == *canceled* ]]; then
          scan_state="canceled"
        elif [[ "$scan_line" == *completed* || "$scan_line" == *"with "*"errors on"* || "$scan_line" == *repaired* ]]; then
          scan_state="completed"
        fi
        # Completion timestamp: extract the " on <Day Mon DD HH:MM:SS YYYY>" tail
        # and try to normalize. If we can't parse, leave null.
        if [[ "$scan_line" =~ \ on\ ([A-Z][a-z]{2}\ [A-Z][a-z]{2}\ +[0-9]+\ [0-9:]+\ [0-9]{4})$ ]]; then
          ts_raw="${BASH_REMATCH[1]}"
          if iso_ts=$(date -u -d "$ts_raw" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null); then
            last_completed="\"$iso_ts\""
          fi
        fi
        # Errors: "with N errors"
        if [[ "$scan_line" =~ with\ ([0-9]+)\ errors ]]; then
          errors_found="${BASH_REMATCH[1]}"
        fi

        obs=$(jq -n -c \
          --arg subject "$pool" \
          --arg pool "$pool" \
          --arg scan_type "$scan_type" \
          --arg scan_state "$scan_state" \
          --argjson last_completed "$last_completed" \
          --argjson errors_found "$errors_found" \
          '{kind:"zfs_scan", subject:$subject, pool:$pool, scan_type:$scan_type, scan_state:$scan_state, last_completed_at:$last_completed, errors_found:$errors_found}'
        )
        append_observation "$obs"
        ;;
      VDEV)
        IFS=$'\t' read -r pool name state read_err write_err cksum_err note <<< "$rest"
        # zpool status -P emits vdev names as absolute paths
        # (/dev/disk/by-id/wwn-... or /dev/sdX). Strip the prefix and
        # any -partN suffix so subject is a readable identifier.
        short_name="${name##*/}"
        short_name="${short_name%-part[0-9]*}"
        subject="${pool}/${short_name}"
        # MVP does not resolve vdev_path / vdev_guid / vdev_type; those
        # require additional tooling (zdb, udev paths). Report what we have.
        note_json="null"
        if [[ -n "$note" ]]; then
          note_json=$(jq -Rn --arg n "$note" '$n')
        fi
        obs=$(jq -n -c \
          --arg subject "$subject" \
          --arg pool "$pool" \
          --arg name "$name" \
          --arg state "$state" \
          --argjson read "$read_err" \
          --argjson write "$write_err" \
          --argjson cksum "$cksum_err" \
          --argjson note "$note_json" \
          '{kind:"zfs_vdev", subject:$subject, pool:$pool, vdev_name:$name, state:$state, read_errors:$read, write_errors:$write, checksum_errors:$cksum, status_note:$note, is_spare:false, is_replacing:false}'
        )
        append_observation "$obs"
        ;;
      SPARE)
        IFS=$'\t' read -r pool name spare_state spare_note <<< "$rest"
        subject="${pool}/spare/${name}"
        is_active="false"
        [[ "$spare_state" == "INUSE" ]] && is_active="true"
        obs=$(jq -n -c \
          --arg subject "$subject" \
          --arg pool "$pool" \
          --arg name "$name" \
          --arg state "$spare_state" \
          --argjson is_active "$is_active" \
          '{kind:"zfs_spare", subject:$subject, pool:$pool, spare_name:$name, state:$state, is_active:$is_active, replacing_vdev_guid:null}'
        )
        append_observation "$obs"
        ;;
      POOL_ERRORS)
        IFS=$'\t' read -r pool err_line <<< "$rest"
        if [[ "$err_line" != "No known data errors" ]]; then
          append_error "pool_data_errors" "pool ${pool}: ${err_line}"
        fi
        ;;
    esac
  done <<< "$parsed"
fi

# ---------------------------------------------------------------------------
# Build standing — derived from can_testify.
# ---------------------------------------------------------------------------

authoritative_for='[]'
if jq -e 'index("pool_state")' <<< "$can_testify" >/dev/null; then
  authoritative_for=$(jq -c '. + ["current_pool_state"]' <<< "$authoritative_for")
fi
if jq -e 'index("vdev_state")' <<< "$can_testify" >/dev/null; then
  authoritative_for=$(jq -c '. + ["current_vdev_state"]' <<< "$authoritative_for")
fi
if jq -e 'index("vdev_error_counters")' <<< "$can_testify" >/dev/null; then
  authoritative_for=$(jq -c '. + ["current_vdev_error_counts"]' <<< "$authoritative_for")
fi
if jq -e 'index("scrub_completion")' <<< "$can_testify" >/dev/null; then
  authoritative_for=$(jq -c '. + ["last_scrub_completion"]' <<< "$authoritative_for")
fi
if jq -e 'index("spare_state")' <<< "$can_testify" >/dev/null; then
  authoritative_for=$(jq -c '. + ["spare_assignment"]' <<< "$authoritative_for")
fi

advisory_for='["chronic_vs_worsening_regime_classification"]'
# Per SPEC §Partial collection, if vdev-level coverage is missing, the
# advisory standing for regime classification must also be demoted.
if ! jq -e 'index("vdev_error_counters")' <<< "$can_testify" >/dev/null; then
  advisory_for='[]'
fi

inadmissible_for='["drive_smart_health","authorization","remediation"]'

# ---------------------------------------------------------------------------
# Finalize + emit
# ---------------------------------------------------------------------------

end_ns=$(date +%s%N)
duration_ms=$(( (end_ns - start_ns) / 1000000 ))

witness_obj=$(jq -n -c \
  --arg id "$id" \
  --arg type "$WITNESS_TYPE" \
  --arg host "$host" \
  --arg profile_version "$PROFILE_VERSION" \
  --arg collected_at "$collected_at" \
  --argjson duration_ms "$duration_ms" \
  --arg status "$status" \
  '{id:$id, type:$type, host:$host, profile_version:$profile_version, collection_mode:"sudo_helper", privilege_model:"unprivileged", collected_at:$collected_at, duration_ms:$duration_ms, status:$status}'
)

coverage_obj=$(jq -n -c \
  --argjson ct "$can_testify" \
  --argjson nt "$cannot_testify" \
  '{can_testify:$ct, cannot_testify:$nt}'
)

standing_obj=$(jq -n -c \
  --argjson a "$authoritative_for" \
  --argjson av "$advisory_for" \
  --argjson i "$inadmissible_for" \
  '{authoritative_for:$a, advisory_for:$av, inadmissible_for:$i}'
)

jq -n \
  --arg schema "$SCHEMA" \
  --argjson witness "$witness_obj" \
  --argjson coverage "$coverage_obj" \
  --argjson standing "$standing_obj" \
  --argjson observations "$observations_json" \
  --argjson errors "$errors_json" \
  '{schema:$schema, witness:$witness, coverage:$coverage, standing:$standing, observations:$observations, errors:$errors}'
