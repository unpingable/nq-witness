#!/usr/bin/env python3
# nq-zfs-witness — reference ZFS witness conforming to
# nq.witness.v0 / nq.witness.zfs.v0.
#
# Status: clarify pass (bash → Python). Not production code.
# Deployment: runs as an unprivileged subprocess when /dev/zfs
# permissions allow non-root reads (the default shape). A sudo-
# NOPASSWD wrapper may set NQ_COLLECTION_MODE=sudo_helper and
# NQ_PRIVILEGE_MODEL=nopasswd_fixed_helper before exec.
#
# Invocation: no arguments in production. Emits the canonical JSON
# report to stdout, exits 0. --zpool-list-from / --zpool-status-from
# flags exist for fixture-driven testing only.

from __future__ import annotations

import argparse
import json
import os
import re
import socket
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

SCHEMA = "nq.witness.v0"
PROFILE_VERSION = "nq.witness.zfs.v0"
WITNESS_TYPE = "zfs"
MAX_POOLS = 16
MAX_VDEVS_PER_POOL = 256
COLLECTION_TIMEOUT_S = 5

HEALTH_NUMERIC = {
    "ONLINE": 0,
    "DEGRADED": 3,
    "FAULTED": 6,
    "SUSPENDED": 9,
    "OFFLINE": 4,
    "UNAVAIL": 5,
    "REMOVED": 8,
}

GROUP_PREFIXES = (
    "raidz", "mirror", "log-", "cache-", "special-", "dedup-",
)

SCAN_PATTERNS = [
    # "scrub repaired 0B in 04:12:17 with 0 errors on Sun Apr 12 07:26:33 2026"
    # "scrub repaired 123K in 0 days 04:12:17 with 0 errors on ..."
    re.compile(
        r"^scrub repaired \S+ in (?:[\d\s]+days? )?[\d:]+ with (\d+) errors on "
        r"(?P<ts>[A-Z][a-z]{2} [A-Z][a-z]{2}\s+\d+ [\d:]+ \d{4})$"
    ),
    # "resilvered 123M in 04:12:17 with 0 errors on ..."
    re.compile(
        r"^resilvered \S+ in (?:[\d\s]+days? )?[\d:]+ with (\d+) errors on "
        r"(?P<ts>[A-Z][a-z]{2} [A-Z][a-z]{2}\s+\d+ [\d:]+ \d{4})$"
    ),
    # "scrub in progress since Mon Apr 12 07:26:33 2026"
    re.compile(
        r"^(?P<type>scrub|resilver) in progress since "
        r"(?P<ts>[A-Z][a-z]{2} [A-Z][a-z]{2}\s+\d+ [\d:]+ \d{4})$"
    ),
    # "scrub canceled on Thu Dec 25 20:14:37 2025"
    re.compile(
        r"^(?P<type>scrub|resilver) canceled on "
        r"(?P<ts>[A-Z][a-z]{2} [A-Z][a-z]{2}\s+\d+ [\d:]+ \d{4})$"
    ),
    # "none requested"
    re.compile(r"^none requested$"),
]


def utc_now_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_zpool_list(text: str) -> list[dict]:
    """Parse `zpool list -Hp -o name,size,alloc,free,frag,cap,health,readonly`.

    Returns one dict per pool with normalized fields. Raises ValueError on
    a line that does not have the expected 8 tab-separated fields.
    """
    pools: list[dict] = []
    for lineno, line in enumerate(text.splitlines(), 1):
        if not line.strip():
            continue
        parts = line.split("\t")
        if len(parts) != 8:
            raise ValueError(
                f"zpool list line {lineno}: expected 8 fields, got {len(parts)}"
            )
        name, size, alloc, free, frag, _cap, health, readonly_flag = parts
        frag_ratio: float | None
        if frag in ("-", ""):
            frag_ratio = None
        else:
            frag_ratio = round(int(frag) / 100, 4)
        pools.append({
            "name": name,
            "size_bytes": int(size),
            "alloc_bytes": int(alloc),
            "free_bytes": int(free),
            "fragmentation_ratio": frag_ratio,
            "state": health,
            "health_numeric": HEALTH_NUMERIC.get(health, -1),
            "readonly": readonly_flag == "on",
        })
    return pools


def parse_scan_line(scan_line: str) -> tuple[dict, str | None]:
    """Parse a `scan:` line into structured fields.

    Returns (fields, error_detail). On match fields are populated; on
    parse failure error_detail is a non-empty string and fields carries
    scan_state=None so the caller can demote coverage honestly.
    """
    fields = {
        "scan_type": "none",
        "scan_state": "none",
        "last_completed_at": None,
        "errors_found": 0,
    }
    s = scan_line.strip()
    for pat in SCAN_PATTERNS:
        m = pat.match(s)
        if not m:
            continue
        gd = m.groupdict()
        if s.startswith("scrub repaired"):
            fields["scan_type"] = "scrub"
            fields["scan_state"] = "completed"
            fields["errors_found"] = int(m.group(1))
            fields["last_completed_at"] = _rfc_to_iso(gd["ts"])
        elif s.startswith("resilvered"):
            fields["scan_type"] = "resilver"
            fields["scan_state"] = "completed"
            fields["errors_found"] = int(m.group(1))
            fields["last_completed_at"] = _rfc_to_iso(gd["ts"])
        elif "in progress" in s:
            fields["scan_type"] = gd["type"]
            fields["scan_state"] = "in_progress"
        elif "canceled" in s:
            fields["scan_type"] = gd["type"]
            fields["scan_state"] = "canceled"
        # "none requested" leaves defaults.
        return fields, None
    return (
        {"scan_type": None, "scan_state": None,
         "last_completed_at": None, "errors_found": None},
        f"unrecognized scan line: {s!r}",
    )


def _rfc_to_iso(rfc: str) -> str | None:
    for fmt in ("%a %b %d %H:%M:%S %Y", "%a %b  %d %H:%M:%S %Y"):
        try:
            dt = datetime.strptime(rfc, fmt).replace(tzinfo=timezone.utc)
            return dt.strftime("%Y-%m-%dT%H:%M:%SZ")
        except ValueError:
            continue
    return None


def _indent_of(line: str) -> int:
    return len(line) - len(line.lstrip())


def _is_group_name(name: str) -> bool:
    # raidz-0, raidz2-0, mirror-0, log-0, cache-0, special-0, dedup-0.
    return any(name.startswith(p) for p in GROUP_PREFIXES)


def _is_spare_wrapper(name: str) -> bool:
    # spare-0, spare-1 etc. — the compound "spare replacing X" vdev.
    return re.match(r"^spare-\d+$", name) is not None


def parse_zpool_status(text: str) -> dict:
    """Parse `zpool status -P` into pools → {scans, vdevs, spares, pool_errors}.

    Returns a dict keyed by pool name. Each value has:
      scans: list of (raw_scan_line, scan_line_errors|None)
      vdevs: list of leaf device rows with parent-group context
      spares: list of spare-section rows
      pool_errors_raw: the raw `errors:` line text
    """
    out: dict[str, dict] = {}
    current_pool: str | None = None
    section: str | None = None  # "config" | "spares" | None
    # Stack of (indent, name) tracking the current config-tree ancestry.
    stack: list[tuple[int, str]] = []
    # Track whether we're currently inside a spare-N wrapper — its
    # leaf children are marked is_replacing and the spare-named one
    # is_spare. Reset when indent returns to the wrapper's depth or shallower.
    spare_wrapper_indent: int | None = None

    lines = text.splitlines()
    for line in lines:
        stripped = line.strip()
        if not stripped:
            # Blank line resets spare-wrapper tracking.
            spare_wrapper_indent = None
            continue

        # Top-level directive lines (pool:, scan:, config:, errors:, status:, action:, see:).
        m = re.match(r"^\s*pool:\s+(.+)$", line)
        if m:
            current_pool = m.group(1).strip()
            out.setdefault(current_pool, {
                "scans": [], "vdevs": [], "spares": [],
                "pool_errors_raw": None,
            })
            section = None
            stack = []
            spare_wrapper_indent = None
            continue
        m = re.match(r"^\s*scan:\s+(.+)$", line)
        if m and current_pool:
            fields, err = parse_scan_line(m.group(1))
            out[current_pool]["scans"].append((fields, err))
            continue
        if re.match(r"^config:\s*$", line):
            section = "config"
            stack = []
            spare_wrapper_indent = None
            continue
        m = re.match(r"^\s*errors:\s+(.+)$", line)
        if m and current_pool:
            out[current_pool]["pool_errors_raw"] = m.group(1).strip()
            section = None
            continue
        # Skip other directive lines we don't structurally use.
        if re.match(r"^\s*(status|action|see):", line):
            continue

        if section != "config" or current_pool is None:
            continue

        # Inside config. Skip the NAME STATE READ WRITE CKSUM header.
        if re.match(r"^\s+NAME\s+STATE\s+READ\s+WRITE\s+CKSUM", line):
            continue

        indent = _indent_of(line)
        parts = stripped.split()

        # The "spares" pseudo-header line switches to spares section.
        if len(parts) == 1 and parts[0] == "spares":
            section = "spares-header"
            stack = []
            spare_wrapper_indent = None
            continue

        # We've left config proper if we hit non-config content.
        # Everything after this is a row with at least a name.
        name = parts[0]

        # Unwind stack to current indent.
        while stack and stack[-1][0] >= indent:
            popped_indent, popped_name = stack.pop()
            if spare_wrapper_indent is not None and popped_indent <= spare_wrapper_indent:
                spare_wrapper_indent = None

        # Pool-level row (name == current_pool) — skip; it's not a vdev.
        if name == current_pool:
            stack.append((indent, name))
            continue

        # Group row (raidz-0 / mirror-0 / log-0 / cache-0 / special-0 / dedup-0):
        # remember on the stack and move on.
        if _is_group_name(name):
            stack.append((indent, name))
            continue

        # Spare wrapper (spare-0, spare-1 ...): mark descendants as replacing.
        if _is_spare_wrapper(name):
            spare_wrapper_indent = indent
            stack.append((indent, name))
            continue

        # Leaf device row.
        if len(parts) < 5:
            # Malformed line: skip, track via a return-level error? For now
            # we just drop it — the pool state from zpool list still stands.
            continue
        state = parts[1]
        try:
            read_err = int(parts[2])
            write_err = int(parts[3])
            cksum_err = int(parts[4])
        except ValueError:
            continue
        note = " ".join(parts[5:]) if len(parts) > 5 else ""

        # Find nearest group ancestor on the stack (raidz/mirror/etc.).
        parent_group = None
        for _ind, _nm in reversed(stack):
            if _is_group_name(_nm):
                parent_group = _nm
                break

        # Strip /dev/disk/by-id/ prefix and -partN suffix from device name.
        short = name.rsplit("/", 1)[-1]
        short = re.sub(r"-part\d+$", "", short)

        if parent_group:
            subject = f"{current_pool}/{parent_group}/{short}"
        else:
            subject = f"{current_pool}/{short}"

        is_replacing = spare_wrapper_indent is not None and indent > spare_wrapper_indent
        is_spare = is_replacing and short.startswith(("ata-", "scsi-", "wwn-")) and (
            "SPARE" in short.upper() or "spare" in short
        )

        out[current_pool]["vdevs"].append({
            "subject": subject,
            "pool": current_pool,
            "vdev_name": name,
            "state": state,
            "read_errors": read_err,
            "write_errors": write_err,
            "checksum_errors": cksum_err,
            "status_note": note or None,
            "is_spare": is_spare,
            "is_replacing": is_replacing,
        })
        stack.append((indent, name))

    # After the config block the "spares" section is parsed on its own.
    # Re-scan to pick up spare-section rows. This is separate from vdev
    # parsing because the columns differ ("ata-X AVAIL" vs vdev columns).
    _parse_spares_section(lines, out)

    return out


def _parse_spares_section(lines: list[str], out: dict[str, dict]) -> None:
    """Second-pass: walk through 'spares' sections and collect spare rows."""
    current_pool: str | None = None
    in_spares = False
    for line in lines:
        m = re.match(r"^\s*pool:\s+(.+)$", line)
        if m:
            current_pool = m.group(1).strip()
            in_spares = False
            continue
        if re.match(r"^config:\s*$", line):
            in_spares = False
            continue
        if re.match(r"^\s*errors:", line):
            in_spares = False
            continue
        if line.strip() == "spares":
            in_spares = True
            continue
        if not in_spares or current_pool is None:
            continue
        stripped = line.strip()
        if not stripped:
            in_spares = False
            continue
        parts = stripped.split()
        if len(parts) < 2:
            continue
        name = parts[0]
        state = parts[1]
        note = " ".join(parts[2:]) if len(parts) > 2 else ""
        out.setdefault(current_pool, {
            "scans": [], "vdevs": [], "spares": [],
            "pool_errors_raw": None,
        })
        out[current_pool]["spares"].append({
            "name": name,
            "state": state,
            "note": note,
        })


def build_report(
    host: str,
    pool_rows: list[dict] | None,
    pool_rows_error: str | None,
    status_by_pool: dict[str, dict] | None,
    status_error: str | None,
    start_ns: int,
    collected_at: str,
    collection_mode: str,
    privilege_model: str,
) -> dict:
    errors: list[dict] = []
    can_testify: list[str] = []
    # Seed with the profile-required tags (§Required coverage.can_testify
    # tags) plus tags this implementation structurally does not source.
    # Successful collection steps move tags out of this list into
    # can_testify via add_tag; unsourced tags stay here, which is the
    # SPEC §Coverage "honest rule" — silence equals admission is the
    # failure mode this list prevents.
    cannot_testify: list[str] = [
        "pool_state",
        "pool_capacity",
        "vdev_state",
        "vdev_error_counters",
        "scrub_state",
        "scrub_completion",
        "spare_state",
        "smart_drive_health",
        "enclosure_slot_mapping",
        "dataset_capacity",
        "dataset_properties",
    ]
    observations: list[dict] = []
    status = "ok"

    def add_error(kind: str, detail: str) -> None:
        errors.append({
            "kind": kind,
            "detail": detail,
            "observed_at": utc_now_iso(),
        })

    def add_tag(tag: str) -> None:
        if tag not in can_testify:
            can_testify.append(tag)
        if tag in cannot_testify:
            cannot_testify.remove(tag)

    def demote_tag(tag: str) -> None:
        if tag in can_testify:
            can_testify.remove(tag)
        if tag not in cannot_testify:
            cannot_testify.append(tag)

    # zpool list → zfs_pool observations.
    if pool_rows is None:
        add_error("zpool_list_failed", pool_rows_error or "unknown failure")
        status = "failed"
    else:
        add_tag("pool_state")
        add_tag("pool_capacity")
        add_tag("fragmentation")
        add_tag("readonly_flag")
        if len(pool_rows) > MAX_POOLS:
            add_error(
                "pool_count_exceeded_cap",
                f"found {len(pool_rows)} pools, cap is {MAX_POOLS}; truncating",
            )
            status = "partial"
            pool_rows = pool_rows[:MAX_POOLS]
        for p in pool_rows:
            observations.append({
                "kind": "zfs_pool",
                "subject": p["name"],
                "state": p["state"],
                "health_numeric": p["health_numeric"],
                "size_bytes": p["size_bytes"],
                "alloc_bytes": p["alloc_bytes"],
                "free_bytes": p["free_bytes"],
                "readonly": p["readonly"],
                "fragmentation_ratio": p["fragmentation_ratio"],
            })

    # zpool status → vdev / scan / spare observations + pool-error lines.
    if status_by_pool is None:
        add_error("zpool_status_failed", status_error or "unknown failure")
        if status == "ok":
            status = "partial"
        # Do not add vdev/scan/spare tags; their absence is honest.
    else:
        add_tag("vdev_state")
        add_tag("vdev_error_counters")
        add_tag("scrub_state")
        add_tag("scrub_completion")
        add_tag("spare_state")

        # Scan observations: emit only if the scan line parsed. Any parse
        # failure demotes both scrub_state and scrub_completion for the
        # whole cycle — we don't know the state or the timestamp, so per
        # SPEC §Partial collection we can't emit half-observations either.
        any_scan_unparsed = any(
            err is not None
            for data in status_by_pool.values()
            for _fields, err in data["scans"]
        )
        if any_scan_unparsed:
            for data in status_by_pool.values():
                for _fields, err in data["scans"]:
                    if err is not None:
                        add_error("scan_line_unparsed", err)
            demote_tag("scrub_state")
            demote_tag("scrub_completion")
            if status == "ok":
                status = "partial"
        else:
            for pool_name, data in status_by_pool.items():
                for fields, _err in data["scans"]:
                    observations.append({
                        "kind": "zfs_scan",
                        "subject": pool_name,
                        "pool": pool_name,
                        "scan_type": fields["scan_type"],
                        "scan_state": fields["scan_state"],
                        "last_completed_at": fields["last_completed_at"],
                        "errors_found": fields["errors_found"],
                    })

        for pool_name, data in status_by_pool.items():

            # Vdevs. Cap at MAX_VDEVS_PER_POOL.
            vdevs = data["vdevs"][:MAX_VDEVS_PER_POOL]
            if len(data["vdevs"]) > MAX_VDEVS_PER_POOL:
                add_error(
                    "vdev_count_exceeded_cap",
                    f"pool {pool_name}: {len(data['vdevs'])} vdevs, cap is {MAX_VDEVS_PER_POOL}",
                )
                if status == "ok":
                    status = "partial"
            for v in vdevs:
                observations.append({
                    "kind": "zfs_vdev",
                    "subject": v["subject"],
                    "pool": v["pool"],
                    "vdev_name": v["vdev_name"],
                    "state": v["state"],
                    "read_errors": v["read_errors"],
                    "write_errors": v["write_errors"],
                    "checksum_errors": v["checksum_errors"],
                    "status_note": v["status_note"],
                    "is_spare": v["is_spare"],
                    "is_replacing": v["is_replacing"],
                })

            # Spares. This branch is untested against a deployment with real
            # spares (lil-nas-x has none); the fixture exercises it abstractly.
            for sp in data["spares"]:
                is_active = sp["state"] == "INUSE"
                observations.append({
                    "kind": "zfs_spare",
                    "subject": f"{pool_name}/spare/{sp['name']}",
                    "pool": pool_name,
                    "spare_name": sp["name"],
                    "state": sp["state"],
                    "is_active": is_active,
                    "replacing_vdev_guid": None,
                })

            # Pool-level errors. Structured check for the stable "clean" string;
            # anything else surfaces as a pool_data_errors entry in errors[].
            err_line = data["pool_errors_raw"]
            if err_line is not None and err_line != "No known data errors":
                add_error("pool_data_errors", f"pool {pool_name}: {err_line}")

    # Build standing from current can_testify.
    authoritative: list[str] = []
    if "pool_state" in can_testify:
        authoritative.append("current_pool_state")
    if "vdev_state" in can_testify:
        authoritative.append("current_vdev_state")
    if "vdev_error_counters" in can_testify:
        authoritative.append("current_vdev_error_counts")
    if "scrub_completion" in can_testify:
        authoritative.append("last_scrub_completion")
    if "spare_state" in can_testify:
        authoritative.append("spare_assignment")

    advisory = (
        ["chronic_vs_worsening_regime_classification"]
        if "vdev_error_counters" in can_testify
        else []
    )
    inadmissible = ["drive_smart_health", "authorization", "remediation"]

    duration_ms = (time.monotonic_ns() - start_ns) // 1_000_000

    return {
        "schema": SCHEMA,
        "witness": {
            "id": f"zfs.local.{host}",
            "type": WITNESS_TYPE,
            "host": host,
            "profile_version": PROFILE_VERSION,
            "collection_mode": collection_mode,
            "privilege_model": privilege_model,
            "collected_at": collected_at,
            "duration_ms": duration_ms,
            "status": status,
        },
        "coverage": {
            "can_testify": can_testify,
            "cannot_testify": cannot_testify,
        },
        "standing": {
            "authoritative_for": authoritative,
            "advisory_for": advisory,
            "inadmissible_for": inadmissible,
        },
        "observations": observations,
        "errors": errors,
    }


def _run(cmd: list[str], timeout_s: int) -> tuple[str | None, str | None]:
    try:
        proc = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout_s,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return None, f"{cmd[0]} timed out after {timeout_s}s"
    except FileNotFoundError:
        return None, f"{cmd[0]} not found on PATH"
    if proc.returncode != 0:
        return None, (
            f"{cmd[0]} exited {proc.returncode}: {proc.stderr.strip()[:200]}"
        )
    return proc.stdout, None


def detect_invocation_context() -> tuple[str, str]:
    """Return (collection_mode, privilege_model) based on env / process uid.

    Defaults: subprocess + unprivileged. Overridable via env vars for
    deployments that wrap this helper in a sudo-NOPASSWD invocation.
    """
    mode = os.environ.get("NQ_COLLECTION_MODE")
    priv = os.environ.get("NQ_PRIVILEGE_MODEL")
    if mode and priv:
        return mode, priv
    if os.environ.get("SUDO_UID"):
        return "sudo_helper", "nopasswd_fixed_helper"
    return "subprocess", "unprivileged"


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument("--zpool-list-from", type=Path, default=None,
                        help="Read zpool list output from file (for testing)")
    parser.add_argument("--zpool-status-from", type=Path, default=None,
                        help="Read zpool status output from file (for testing)")
    parser.add_argument("--host", default=None,
                        help="Override reported hostname (for testing)")
    args = parser.parse_args(argv)

    start_ns = time.monotonic_ns()
    collected_at = utc_now_iso()
    host = args.host or socket.gethostname()
    collection_mode, privilege_model = detect_invocation_context()

    # zpool list.
    if args.zpool_list_from is not None:
        pool_text = args.zpool_list_from.read_text()
        list_err: str | None = None
    else:
        pool_text, list_err = _run(
            ["zpool", "list", "-Hp", "-o",
             "name,size,alloc,free,frag,cap,health,readonly"],
            COLLECTION_TIMEOUT_S,
        )

    pool_rows: list[dict] | None = None
    if pool_text is not None:
        try:
            pool_rows = parse_zpool_list(pool_text)
        except ValueError as e:
            pool_rows = None
            list_err = f"zpool list parse error: {e}"

    # zpool status.
    if args.zpool_status_from is not None:
        status_text = args.zpool_status_from.read_text()
        status_err: str | None = None
    else:
        status_text, status_err = _run(
            ["zpool", "status", "-P"],
            COLLECTION_TIMEOUT_S,
        )

    status_by_pool: dict[str, dict] | None = None
    if status_text is not None:
        try:
            status_by_pool = parse_zpool_status(status_text)
        except Exception as e:
            status_by_pool = None
            status_err = f"zpool status parse error: {e}"

    report = build_report(
        host=host,
        pool_rows=pool_rows,
        pool_rows_error=list_err,
        status_by_pool=status_by_pool,
        status_error=status_err,
        start_ns=start_ns,
        collected_at=collected_at,
        collection_mode=collection_mode,
        privilege_model=privilege_model,
    )
    json.dump(report, sys.stdout, separators=(",", ":"))
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
